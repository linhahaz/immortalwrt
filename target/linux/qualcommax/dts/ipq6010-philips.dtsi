/dts-v1/;

#include "ipq6018.dtsi"
#include "ipq6018-ess.dtsi"
#include "ipq6018-nss.dtsi"
#include "ipq6018-common.dtsi"

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/leds/common.h>

/ {
	aliases {
		serial0 = &blsp1_uart3;

		led-boot = &led_status_blue;
		led-failsafe = &led_status_red;
		led-running = &led_status_green;
		led-upgrade = &led_status_red;

		ethernet1 = &swport2;
		ethernet2 = &swport3;
		ethernet3 = &swport4;
		ethernet4 = &swport5;
	};

	chosen {
		stdout-path = "serial0:115200n8";
	};

	keys {
		compatible = "gpio-keys";

		reset {
			label = "reset";
			linux,code = <KEY_RESTART>;
			gpios = <&tlmm 9 GPIO_ACTIVE_LOW>;
		};
	};

	leds {
		compatible = "gpio-leds";

		led_status_red: status-red {
			color = <LED_COLOR_ID_RED>;
			function = LED_FUNCTION_STATUS;
			gpios = <&tlmm 37 GPIO_ACTIVE_HIGH>;
		};

		led_status_green: status-green {
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_STATUS;
			gpios = <&tlmm 50 GPIO_ACTIVE_HIGH>;
		};

		led_status_blue: status-blue {
			color = <LED_COLOR_ID_BLUE>;
			function = LED_FUNCTION_STATUS;
			gpios = <&tlmm 35 GPIO_ACTIVE_HIGH>;
		};
	};
};

&blsp1_spi1 {
	status = "okay";

	flash@0 {
		compatible = "jedec,spi-nor";
		spi-max-frequency = <50000000>;
		reg = <0>;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			partition@0 {
				label = "0:SBL1";
				reg = <0x00000000 0x000c0000>;
			};

			partition@c0000 {
				label = "0:MIBIB";
				reg = <0x000c0000 0x00010000>;
			};

			partition@d0000 {
				label = "0:BOOTCONFIG";
				reg = <0x000d0000 0x00020000>;
			};

			partition@f0000 {
				label = "0:BOOTCONFIG1";
				reg = <0x000f0000 0x00020000>;
			};

			partition@110000 {
				label = "0:QSEE";
				reg = <0x00110000 0x001a0000>;
			};

			partition@2b0000 {
				label = "0:QSEE_1";
				reg = <0x002b0000 0x001a0000>;
			};

			partition@450000 {
				label = "0:DEVCFG";
				reg = <0x00450000 0x00010000>;
			};

			partition@460000 {
				label = "0:DEVCFG_1";
				reg = <0x00460000 0x00010000>;
			};

			partition@470000 {
				label = "0:RPM";
				reg = <0x00470000 0x00040000>;
			};

			partition@4b0000 {
				label = "0:RPM_1";
				reg = <0x004b0000 0x00040000>;
			};

			partition@4f0000 {
				label = "0:CDT";
				reg = <0x004f0000 0x00010000>;
			};

			partition@500000 {
				label = "0:CDT_1";
				reg = <0x00500000 0x00010000>;
			};

			partition@510000 {
				label = "0:APPSBLENV";
				reg = <0x00510000 0x00010000>;
			};

			partition@520000 {
				label = "0:APPSBL";
				reg = <0x00520000 0x000a0000>;
			};

			partition@5c0000 {
				label = "0:APPSBL_1";
				reg = <0x005c0000 0x000a0000>;
			};

			partition@660000 {
				label = "0:ART";
				reg = <0x00660000 0x00040000>;
			};
		};
	};
};

&sdhc {
	status = "okay";

	bus-width = <8>;
	mmc-ddr-1_8v;
	mmc-hs200-1_8v;
	non-removable;
};

&mdio {
	status = "okay";

	pinctrl-0 = <&mdio_pins>;
	pinctrl-names = "default";
	reset-gpios = <&tlmm 75 GPIO_ACTIVE_LOW>;

	ethernet-phy-package@0 {
		compatible = "qcom,qca8075-package";
		#address-cells = <1>;
		#size-cells = <0>;
		reg = <0>;

		qca8075_1: ethernet-phy@1 {
			compatible = "ethernet-phy-ieee802.3-c22";
			reg = <1>;
		};

		qca8075_2: ethernet-phy@2 {
			compatible = "ethernet-phy-ieee802.3-c22";
			reg = <2>;
		};

		qca8075_3: ethernet-phy@3 {
			compatible = "ethernet-phy-ieee802.3-c22";
			reg = <3>;
		};

		qca8075_4: ethernet-phy@4 {
			compatible = "ethernet-phy-ieee802.3-c22";
			reg = <4>;
		};
	};
};

&switch {
	status = "okay";

	ports {
		#address-cells = <1>;
		#size-cells = <0>;

		port@0 {
			reg = <0>;
			ethernet = <&edma>;
			phy-mode = "internal";

			fixed-link {
				speed = <1000>;
				full-duplex;
			};
		};

		swport2: port@2 {
			reg = <2>;
			label = "lan1";
			phy-handle = <&qca8075_1>;
			phy-mode = "psgmii";
			pcs-handle = <&uniphy0 1>;
		};

		swport3: port@3 {
			reg = <3>;
			label = "lan2";
			phy-handle = <&qca8075_2>;
			phy-mode = "psgmii";
			pcs-handle = <&uniphy0 2>;
		};

		swport4: port@4 {
			reg = <4>;
			label = "lan3";
			phy-handle = <&qca8075_3>;
			phy-mode = "psgmii";
			pcs-handle = <&uniphy0 3>;
		};

		swport5: port@5 {
			reg = <5>;
			label = "wan";
			phy-handle = <&qca8075_4>;
			phy-mode = "psgmii";
			pcs-handle = <&uniphy0 4>;
		};
	};
};

&edma {
	status = "okay";
};
