/dts-v1/;

#include "ipq6010-re-cs.dtsi"

/ {
	model = "JDCloud RE-CS-02";
	compatible = "jdcloud,re-cs-02", "qcom,ipq6018";

	aliases {
		ethernet0 = &swport1;
		ethernet1 = &swport2;
		ethernet2 = &swport3;
		ethernet3 = &swport4;
		ethernet4 = &swport5;

		label-mac-device = &swport1;
	};

	keys {
		compatible = "gpio-keys";

		reset {
			label = "reset";
			linux,code = <KEY_RESTART>;
			gpios = <&tlmm 56 GPIO_ACTIVE_LOW>;
		};

		screen {
			label = "screen";
			linux,code = <BTN_1>;
			gpios = <&tlmm 71 GPIO_ACTIVE_LOW>;
		};

		wps {
			label = "wps";
			linux,code = <KEY_WPS_BUTTON>;
			gpios = <&tlmm 72 GPIO_ACTIVE_LOW>;
		};
	};
};

&tlmm {
	tmp1628_pins: tmp1628-pins {
		pins = "gpio69", "gpio70", "gpio73", "gpio74";
		function = "gpio";
		drive-strength = <8>;
		bias-pull-down;
	};
};

&pcie0 {
	status = "okay";
	perst-gpios = <&tlmm 53 GPIO_ACTIVE_LOW>;

	pcie@0 {
		wifi@0,0 {
			status = "okay";
			compatible = "pci17cb,1104";
			qcom,ath11k-fw-memory-mode = <1>;
			qcom,ath11k-calibration-variant = "JDC-RE-CS-02";
			reg = <0x00010000 0 0 0 0>;
		};
	};
};

&mdio {
	qca8081: ethernet-phy@12 {
		compatible = "ethernet-phy-id004d.d101";
		reg = <12>;
		reset-deassert-us = <10000>;
		reset-gpios = <&tlmm 77 GPIO_ACTIVE_LOW>;
	};
};

&uniphy1 {
	status = "okay";
};

&switch {
	status = "okay";

	ports {
		#address-cells = <1>;
		#size-cells = <0>;

		port@0 {
			reg = <0>;
			ethernet = <&edma>;
			phy-mode = "internal";

			fixed-link {
				speed = <1000>;
				full-duplex;
			};
		};

		swport1: port@1 {
			reg = <1>;
			label = "lan1";
			phy-handle = <&qca8075_0>;
			phy-mode = "psgmii";
			pcs-handle = <&uniphy0 0>;
		};

		swport2: port@2 {
			reg = <2>;
			label = "lan2";
			phy-handle = <&qca8075_1>;
			phy-mode = "psgmii";
			pcs-handle = <&uniphy0 1>;
		};

		swport3: port@3 {
			reg = <3>;
			label = "lan3";
			phy-handle = <&qca8075_2>;
			phy-mode = "psgmii";
			pcs-handle = <&uniphy0 2>;
		};

		swport4: port@4 {
			reg = <4>;
			label = "lan4";
			phy-handle = <&qca8075_3>;
			phy-mode = "psgmii";
			pcs-handle = <&uniphy0 3>;
		};

		swport5: port@5 {
			reg = <5>;
			label = "wan";
			phy-handle = <&qca8081>;
			phy-mode = "2500base-x";
			pcs-handle = <&uniphy1 0>;
		};
	};
};

&edma {
	status = "okay";
};

&wifi {
	status = "okay";
	qcom,ath11k-fw-memory-mode = <1>;
	qcom,ath11k-calibration-variant = "JDC-RE-CS-02";
};
